{
    "CacheSettings": {
        "Static": {
            // Http Header maxage
            "maxage": 86400,
            "key": "static:all"
        }
    },
    "Logging": {
        "LogLevel": {
            "Default": "Warning",
            "Microsoft.Hosting.Lifetime": "Warning",
            "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
